# Server
PORT=4000
JWT_SECRET=change_me
ADMIN_USER=admin
ADMIN_PASS=your_password_here
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=120

# Storage
STORAGE_ADAPTER=json # or postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname

# External services
VITE_API_BASE_URL=http://localhost:4000
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ADMIN_EMAIL=
SMS_PROVIDER=arkesel # or paystack
ARKESEL_API_KEY=
ARKESEL_SMS_URL=
ARKESEL_SENDER=
PAYSTACK_SECRET_KEY=
PAYSTACK_SMS_URL=
ADMIN_SMS_NUMBER=
# Optional: set a full API URL for the Vite frontend.
# Leave empty in local dev to use Vite proxy (/api -> http://localhost:4000)
VITE_API_BASE_URL=
# Cloudinary (for image storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
